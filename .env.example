# ── Slack ─────────────────────────────────────────────────────────────────────
# From your Slack App's "OAuth & Permissions" page
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# From your Slack App's "Basic Information" page
SLACK_SIGNING_SECRET=your-signing-secret-here

# ── LLM provider keys ─────────────────────────────────────────────────────────
# Only the key for your chosen model(s) is required.
# Set the model in each RESEARCHER_PERSONA / EVALUATOR_PERSONA in config.py.

# Anthropic — required for any claude-* model (default)
# Claude Code CLI (Coder agent) always needs this regardless of model choice.
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# OpenAI — required for any gpt-*, o1-*, o3-*, o4-* model
OPENAI_API_KEY=sk-your-openai-key-here

# Google — required for any gemini-* model
GOOGLE_API_KEY=your-google-api-key-here

# ── GitHub ─────────────────────────────────────────────────────────────────────
# Builder clones this repo, lets Claude Code do the work, then opens a PR.
# Token needs: repo + pull_request scopes
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your-github-token-here

# Target repo for PRs, e.g. "myorg/my-project"
# Leave empty → Builder skips push/PR and uploads a zip to Slack instead.
GITHUB_REPO=myorg/my-project

# Base branch PRs are opened against
GITHUB_BASE_BRANCH=main

# ── Web Search & Scraping for Researcher ──────────────────────────────────────────
# Choose your provider: "tavily" (default), "zenrows", or "basic"
WEB_SEARCH_PROVIDER=tavily

# Tavily — AI-powered search API (best for research)
# Free tier at https://tavily.com
TAVILY_API_KEY=tvly-your-api-key-here

# Zenrows — Web scraping with JS rendering (good for scraping complex sites)
# Sign up at https://www.zenrows.com
ZENROWS_API_KEY=your-zenrows-api-key-here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── Database paths (auto-created) ──────────────────────────────────────────────
DB_PATH=./data/amigos.db
CHECKPOINT_DB=./data/checkpoints.db

# ── Jira (Researcher reads/creates tickets — all optional) ─────────────────────────
# Your Atlassian site, e.g. "yourco.atlassian.net"
JIRA_URL=yourco.atlassian.net

# Email associated with the API token below
JIRA_EMAIL=you@company.com

# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-api-token-here

# Project key where Researcher creates Coder tickets, e.g. "ENG" or "PROJ"
# Leave empty to disable ticket creation (Researcher can still read tickets)
JIRA_PROJECT_KEY=PROJ

# ── Researcher mode ──────────────────────────────────────────────────────────────
# Set to "true" to run Researcher via Claude Code CLI (uses Claude Max quota)
# instead of direct API calls.  "false" (default) uses create_react_agent.
RESEARCHER_USE_CLAUDE_CODE=false

# ── Agent names (optional — rename your team personas) ─────────────────────────
# These names appear as the Slack username for each agent's messages.
RESEARCHER_NAME=Archie
CODER_NAME=Builder
EVALUATOR_NAME=Eval

# ── Agent models (optional — override the default models) ──────────────────────
# Set specific Claude models for each agent persona
RESEARCHER_MODEL=claude-opus-4-6
CODER_MODEL=claude-sonnet-4-6
EVALUATOR_MODEL=claude-sonnet-4-6
